# Copy this to .env.local and fill in values. Never commit .env.local.

# Anthropic API key — required for AI features (AI_MODE=anthropicDirect only)
ANTHROPIC_API_KEY=

# SQLite database path
DATABASE_URL="file:./data/data.db"

# Your identity (used for audit log and settings)
APP_USER_EMAIL=
APP_USER_NAME=

# AI provider mode:
#   disabled        — all AI buttons show "Enter manually" (default at work)
#   clipboard       — generates prompt, copies to clipboard, waits for pasted response
#   anthropicDirect — calls api.anthropic.com directly (home laptop only, with synthetic data)
#   bedrock         — AWS Bedrock (future, when approved)
AI_MODE=disabled
